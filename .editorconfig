# EditorConfig for V-COMM Project
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Rust files
[*.rs]
indent_size = 4
max_line_length = 100
tab_width = 4

# TOML files (Cargo)
[*.toml]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# Shell scripts
[*.{sh,bash}]
indent_size = 2
end_of_line = lf

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# JavaScript/TypeScript files
[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

# HTML/CSS files
[*.{html,css,scss}]
indent_size = 2

# SQL files
[*.sql]
indent_size = 2

# Makefiles (must use tabs)
[Makefile]
indent_style = tab

# Docker files
[*{Dockerfile*,docker-compose*}]
indent_size = 2

# Terraform files
[*.tf]
indent_size = 2

# Go files
[*.go]
indent_size = 4

# C/C++ files
[*.{c,cpp,h,hpp}]
indent_size = 4

# WebAssembly files
[*.wat]
indent_size = 2

# Configuration files
[*.{conf,config,env}]
indent_size = 2