{
  "name": "@vcomm/types",
  "version": "0.1.0",
  "description": "Shared type definitions for V-COMM voice communication platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "vcomm",
    "types",
    "voice",
    "communication",
    "webrtc"
  ],
  "author": "Vantis Team",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
