{
  "name": "@vcomm/sentry-config",
  "version": "0.0.1",
  "description": "Sentry configuration and utilities for V-COMM",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "sentry",
    "telemetry",
    "error-tracking",
    "v-comm"
  ],
  "author": "Vantis Corporation",
  "license": "AGPL-3.0",
  "dependencies": {
    "@sentry/node": "^7.100.0",
    "@sentry/react": "^7.100.0",
    "@sentry/tracing": "^7.100.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}