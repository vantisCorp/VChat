{
  "name": "@vcomm/access-portal",
  "version": "0.1.0",
  "description": "Access management portal with RBAC, OAuth integration, and audit logging for V-COMM",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "vcomm",
    "access-control",
    "rbac",
    "oauth",
    "audit-logging"
  ],
  "author": "Vantis Corporation",
  "license": "MIT",
  "dependencies": {
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/uuid": "^11.0.0",
    "typescript": "^5.3.2",
    "tsup": "^8.0.1"
  }
}
