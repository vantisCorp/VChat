{
  "name": "@vcomm/plugin-system",
  "version": "1.0.0",
  "description": "Extensible plugin system for V-COMM with lifecycle management, sandboxing, and marketplace integration",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["vcomm", "plugin", "extension", "addon", "marketplace"],
  "author": "Vantis Corporation",
  "license": "MIT",
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.2",
    "tsup": "^8.0.1"
  }
}
