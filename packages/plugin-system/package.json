{
  "name": "@vcomm/plugin-system",
  "version": "0.1.0",
  "description": "Extensible plugin system for V-COMM with lifecycle management, sandboxing, and marketplace integration",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "vcomm",
    "plugin",
    "extension",
    "addon",
    "marketplace"
  ],
  "author": "Vantis Corporation",
  "license": "MIT",
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/uuid": "^11.0.0",
    "typescript": "^5.3.2",
    "tsup": "^8.0.1"
  }
}
