{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local",
    "**/.env.*.local"
  ],
  "globalEnv": [
    "NODE_ENV",
    "RUST_BACKTRACE",
    "CARGO_HOME",
    "GITHUB_TOKEN"
  ],
  "tasks": {
    "//build": {},
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        "!.next/cache/**",
        "target/**",
        "!.next/cache/**"
      ],
      "cache": true,
      "persistent": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "//lint": {},
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": true
    },
    "format": {
      "outputs": [],
      "cache": true
    },
    "//type-check": {},
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": true
    },
    "clean": {
      "cache": false
    },
    "//cargo:build": {},
    "cargo:build": {
      "dependsOn": ["^cargo:build"],
      "outputs": [
        "target/**"
      ],
      "cache": true
    },
    "cargo:test": {
      "dependsOn": ["cargo:build"],
      "outputs": [],
      "cache": true
    },
    "cargo:clippy": {
      "dependsOn": ["cargo:build"],
      "outputs": [],
      "cache": true
    },
    "docs:build": {
      "dependsOn": ["^build"],
      "outputs": [
        "docs/build/**",
        "docs/.docusaurus/**"
      ],
      "cache": true
    },
    "docs:serve": {
      "cache": false,
      "persistent": true
    },
    "security:audit": {
      "outputs": [],
      "cache": false
    },
    "security:gitleaks": {
      "outputs": [],
      "cache": false
    }
  },
  "remoteCache": {
    "enabled": true,
    "signature": true,
    "teamId": "vcomm-security"
  }
}